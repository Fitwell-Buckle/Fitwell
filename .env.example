# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/fitwell?sslmode=require

# NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:30100

# Admin access (comma-separated emails allowed to log in)
ADMIN_EMAILS=greg@fitwellbuckle.co,tom@fitwellbuckle.co,oliver@fitwellbuckle.co

# Google OAuth (admin login)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Shopify (Dev Dashboard — tokens are exchanged via client credentials, not static)
SHOPIFY_STORE_DOMAIN=fitwell-buckles.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_WEBHOOK_SECRET=

# PostHog (project token is public/write-only; personal key is a server secret)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
GA4_PROPERTY_ID=

# Google Search Console
GSC_SITE_URL=https://fitwellbuckle.co

# Google Ads
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=

# Meta Ads
META_AD_ACCOUNT_ID=
META_ACCESS_TOKEN=

# Klaviyo (email/SMS — private API key, read scopes: accounts:read,
# campaigns:read, flows:read, lists:read, metrics:read, profiles:read,
# events:read, segments:read). KLAVIYO_NEWSLETTER_LIST_ID is optional;
# if unset the cron picks the largest list and logs a warning.
KLAVIYO_API_KEY=
KLAVIYO_NEWSLETTER_LIST_ID=

# Daily watch-industry brief (newsletter/ engine, runs from GitHub Actions).
# NEWSLETTER_KLAVIYO_LIST_ID is the NEW standalone opt-in list the brief
# drafts target — distinct from KLAVIYO_NEWSLETTER_LIST_ID above, which
# points the extract cron at the main marketing list. The engine's draft
# mode fails loudly until this is set. NEWSLETTER_FROM_EMAIL defaults to
# info@portal.fitwellbuckle.co when unset.
NEWSLETTER_KLAVIYO_LIST_ID=
NEWSLETTER_FROM_EMAIL=
# Dedicated Klaviyo key for the newsletter's DRAFT creation — needs WRITE
# scopes (Campaigns: Full, Templates: Full) that the read-only analytics
# KLAVIYO_API_KEY lacks. Kept separate so the analytics key stays
# least-privilege. Falls back to KLAVIYO_API_KEY if unset.
NEWSLETTER_KLAVIYO_API_KEY=

# BrightData residential proxy — lets the newsletter engine fetch
# Cloudflare-walled sources (WatchPro) from a datacenter IP. Reuse the
# same account/zone as the cannabis newsletter's MJBiz scraper; the creds
# aren't site-specific. Host/port default to brd.superproxy.io:33335.
# Without these, rss-proxied sources fail soft (the rest of the brief
# still ships).
BRIGHTDATA_USERNAME=
BRIGHTDATA_PASSWORD=
BRIGHTDATA_HOST=brd.superproxy.io
BRIGHTDATA_PORT=33335

# Judge.me (product reviews — read-only API token). Generated in
# Judge.me dashboard → Settings → API. JUDGEME_SHOP_DOMAIN is the
# shop's myshopify.com host (e.g. "fitwell-buckles.myshopify.com"),
# used as a query param on every API call along with the token.
JUDGEME_API_TOKEN=
JUDGEME_SHOP_DOMAIN=fitwell-buckles.myshopify.com

# Creator program post detection (both optional — the crons no-op with a
# "skipped" summary until set). YOUTUBE_API_KEY: fresh key from the
# fitwell-ops GCP project, restricted to YouTube Data API v3 (do NOT
# reuse the research-pass key — it's burned in chat transcripts; see
# creator-program.md). APIFY_TOKEN: console.apify.com → Settings → API.
YOUTUBE_API_KEY=
APIFY_TOKEN=

# Google Service Account (for GA4, GSC, Google Ads API access)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Resend (transactional email)
RESEND_API_KEY=
EMAIL_FROM=hello@fitwellbuckle.co

# Anthropic (Claude vision for business-card OCR in the CRM module)
ANTHROPIC_API_KEY=

# WhatsApp (Meta Cloud API) — brings WhatsApp messages from leads/customers into
# the CRM. Create a Meta app + WhatsApp Business number, then:
#  - WHATSAPP_VERIFY_TOKEN: any random string; enter the same value when adding
#    the webhook callback URL (https://admin.fitwellbuckle.co/api/webhooks/whatsapp)
#    in the Meta dashboard so the GET handshake passes.
#  - WHATSAPP_APP_SECRET: the Meta app secret (verifies inbound webhook HMAC).
#  - WHATSAPP_TOKEN: a (permanent) access token for sending replies.
#  - WHATSAPP_PHONE_NUMBER_ID: the WhatsApp Business phone-number id.
# Inbound matching is by phone (lead.phone / customer.phone). Inert until set.
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0

# Grapevine post-purchase survey — shared secret for the webhook at
# /api/webhooks/grapevine. Set the same value in Shopify Admin →
# Apps → Flow → (the Grapevine workflow) → "Send HTTP request" action's
# x-grapevine-secret header. Inert until set — the endpoint 401s
# every request when this env var is unset (refuse-by-default).
# Generate with `openssl rand -base64 32`.
GRAPEVINE_WEBHOOK_SECRET=

# Sentry
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=fitwell

# Vercel Cron
CRON_SECRET=generate-with-openssl-rand-base64-32

# Vercel Blob (production module attachments) — create a Blob store in Vercel
# (Storage → Blob) and paste its read-write token here.
BLOB_READ_WRITE_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:30100
