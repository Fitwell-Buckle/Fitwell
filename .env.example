# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/fitwell?sslmode=require

# NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:30100

# Admin access (comma-separated emails allowed to log in)
ADMIN_EMAILS=greg@fitwellbuckle.co,tom@fitwellbuckle.co,oliver@fitwellbuckle.co

# Google OAuth (admin login)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Shopify
SHOPIFY_STORE_DOMAIN=fitwellbuckle.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_WEBHOOK_SECRET=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
GA4_PROPERTY_ID=

# Google Search Console
GSC_SITE_URL=https://fitwellbuckle.co

# Google Ads
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=

# Google Service Account (for GA4, GSC, Google Ads API access)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Resend (transactional email)
RESEND_API_KEY=
EMAIL_FROM=hello@fitwellbuckle.co

# Sentry
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=fitwell

# Vercel Cron
CRON_SECRET=generate-with-openssl-rand-base64-32

# App
NEXT_PUBLIC_APP_URL=http://localhost:30100
