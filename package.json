{
  "name": "fitwell",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack --port 30100",
    "build": "next build",
    "start": "next start",
    "check": "tsc --noEmit && vitest run",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:prod": "vercel --global-config ~/.vercel-fitwell env pull .env.production.local --environment=production --yes && dotenv -e .env.production.local -- drizzle-kit migrate; rm -f .env.production.local",
    "db:pending": "node --env-file=.env.local --import tsx/esm scripts/check-pending-migrations.ts",
    "db:pending:prod": "vercel --global-config ~/.vercel-fitwell env pull .env.production.local --environment=production --yes && dotenv -e .env.production.local -- node --import tsx/esm scripts/check-pending-migrations.ts; rm -f .env.production.local",
    "check:supplier-login": "node --env-file=.env.local --import tsx/esm scripts/check-supplier-login.ts",
    "check:supplier-login:prod": "bash scripts/check-supplier-login-prod.sh",
    "backfill:portal-logins": "node --env-file=.env.local --import tsx/esm scripts/backfill-portal-logins.ts",
    "backfill:portal-logins:prod": "bash scripts/backfill-portal-logins-prod.sh",
    "db:studio": "drizzle-kit studio",
    "vc": "vercel --global-config ~/.vercel-fitwell",
    "shopify": "node --env-file=.env.local --import tsx/esm scripts/shopify-cli.ts",
    "backfill:shopify": "node --env-file=.env.local --import tsx/esm scripts/backfill-shopify.ts",
    "backfill:posthog": "node --env-file=.env.local --import tsx/esm scripts/backfill-posthog.ts",
    "klaviyo:campaign:draft": "node --env-file=.env.local --import tsx/esm scripts/klaviyo-draft-campaign.ts",
    "klaviyo:flow:spike": "node --env-file=.env.local --import tsx/esm scripts/klaviyo-flow-spike.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@auth/drizzle-adapter": "^1.11.1",
    "@neondatabase/serverless": "^0.10.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@vercel/blob": "^2.4.0",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.38.0",
    "lucide-react": "^0.575.0",
    "mjml": "^5.3.0",
    "next": "^15.5.12",
    "next-auth": "^5.0.0-beta.30",
    "posthog-js": "^1.358.0",
    "posthog-node": "^5.21.2",
    "qr-scanner": "^1.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "resend": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.2",
    "yaml": "^2.9.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/mjml": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.30.0",
    "esbuild": "^0.28.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
